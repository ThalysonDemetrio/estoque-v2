PORT=3000
DATABASE_URL=postgresql://usuario:senha@localhost:5432/estoque
JWT_SECRET=CHANGE_ME_USE_OPENSSL_RAND_BASE64_32    # gere com: openssl rand -base64 32
CORS_ORIGIN=http://localhost:8000
ALLOW_REGISTRATION=false
INVESTIMENTOS_TAB_PIN=CHANGE_ME_BCRYPT_HASH  # Deve ser um hash bcrypt (ou PIN 4-8 digitos p/ dev)

ADMIN_EMAIL=admin@seu-dominio.com
ADMIN_PASSWORD=CHANGE_ME_BEFORE_PRODUCTION          # nunca suba em produção com senha padrão
ADMIN_NOME=Administrador

GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

LEGACY_SYNC_BASE_URL=
LEGACY_SYNC_MAX_RETRIES=3

SERPAPI_KEY=CHANGE_ME                               # não versionar a chave real — use variável no servidor
SERPAPI_GOOGLE_DOMAIN=google.com.br
SERPAPI_LOCATION=Brazil
SERPAPI_BRAZIL_ONLY=false
