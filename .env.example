# =============================================================================
# Ambiente local — raiz do repositório
# =============================================================================
# Copie para ".env" na raiz (não versionado) se quiser sobrescrever defaults do
# docker-compose.yml (Postgres local). Nunca faça commit de ".env".
#
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Linux/macOS)
#
# Backend (API): use backend/.env a partir de backend/.env.example
# VPS (Docker produção): use deploy/.env.vps a partir de deploy/.env.vps.example
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=sua_senha_segura
POSTGRES_DB=estoque
